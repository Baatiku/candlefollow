# IQ Option credentials (required)
IQ_EMAIL=your_email@example.com
IQ_PASSWORD=your_password

# Account type: PRACTICE or REAL
IQ_ACCOUNT_TYPE=PRACTICE

# Trading mode: turbo or digital
TRADING_MODE=turbo

# License key (required if using cloud licensing)
LICENSE_KEY=BESTA-FREE-TRIAL

# Bot API security — set any random string to require X-API-Key header on write endpoints
# Leave empty to disable auth (backward-compatible default)
BOT_API_KEY=

# CORS — restrict dashboard access to your domain (comma-separated)
# Default * allows all origins
ALLOWED_ORIGINS=*

# Auto-start trading on boot (true/false)
AUTO_START=true

# Optional: Supabase (needed for license validation)
SUPABASE_URL=
SUPABASE_KEY=
